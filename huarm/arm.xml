<mujoco model="simple_arm">

    <compiler angle="degree"/>
    <option gravity="0 0 -9.81"/>

    <default>
        <default class="arm">
            <joint damping="0.5"/>
            <geom type="capsule"
                rgba="0.2 0.5 0.8 1"
                density="1000"
                size="0.02"/>
            <position kp="5000" kv="50" ctrlrange="-3.14 3.14"/>
        </default>
    </default>

    <worldbody>

        <!-- Ground -->
        <geom type="plane"
              size="5 5 0.1"
              rgba="0.9 0.9 0.9 1"/>

        <!-- Base -->
        <body name="base" pos="1 0 1" childclass="arm">

            <geom type="sphere"
                  size="0.05 0.05"
                  rgba="0.3 0.3 0.3 1"/>

            <!-- Joint 1 : rotate about Y -->
            <joint name="joint1"
                   type="hinge"
                   axis="0 1 0"/>

            <!-- Link 1 (30 cm) -->
            <body name="link1" pos="0 0 0">
                <!-- <inertial pos="0 0 -0.15" mass="0.25"/>-->

                <geom type="cylinder" fromto="0 0 0   0 0 -0.30"/>

                <!-- Joint 2 : rotate about Y -->
                <body name="joint2_body" pos="0 0 -0.30">

                    <joint name="joint2"
                           type="hinge"
                           axis="0 1 0"/>

                    <!-- Link 2 (5 cm) -->
                    <geom fromto="0 0 0   -0.05 0 0"/>

                    <!-- Joint 3 : rotate about Z -->
                    <body name="joint3_body" pos="-0.05 0 0">

                        <joint name="joint3"
                               type="hinge"
                               axis="0 0 1"/>

                        <!-- Link 3 (30 cm) -->
                        <geom fromto="0 0 0   -0.30 0 0"/>

                        <!-- Joint 4 : rotate about Z -->
                        <body name="joint4_body" pos="-0.30 0 0">

                            <joint name="joint4"
                                   type="hinge"
                                   axis="0 0 1"/>

                            <!-- Link 4 (10 cm) -->
                            <geom fromto="0 0 0   -0.1 0 0"/>
                            
                            <body name="end_effector" pos="-0.1 0 0">

                                <geom type="sphere"
                                      size="0.05"
                                      rgba="0.8 0.2 0.2 1"/>

                                <!-- ================================================================
                                     ARM <-> BOW COUPLING: "rubber hinge"
                                     bow_frog is welded rigidly to the end effector in translation
                                     and in x/y rotation (that's just what being a child body in the
                                     kinematic tree gives you for free), and connected via a single
                                     hinge joint about z. That hinge is not free-spinning: it carries
                                     a torsional spring (stiffness) and damping, so it resists
                                     rotation like a stiff rubber bushing rather than a bare pin
                                     joint or a perfectly rigid weld. Tune stiffness/damping/pos/euler
                                     to taste; the force sensor "bow_arm_contact" (see erhu.xml) reads
                                     the reaction force transmitted through this joint at
                                     "bow_frog_site", i.e. the tension in the "rubber" connection. -->
                                <body name="bow_frog" pos="0 0 -0.05" euler="-1.5708 0 0">

                                    <joint name="bow_frog_hinge"
                                           type="hinge"
                                           axis="0 0 1"
                                           stiffness="1000"
                                           damping="2"
                                           springref="0"/>

                                    <geom name="frog_geom" type="capsule" size="0.008 0.02" rgba="0.2 0.5 0.05 1" mass="0.02"/>

                                    <body name="bow_link_0" pos="0.005 0 0.025" zaxis="1 0 1">
                                        <joint name="bow_hinge_0" type="hinge" axis="1 0 0" class="bow_link"/>
                                        <geom name="bow_geom_0" type="capsule" fromto="0 0 0  0 0 0.05" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.004"/>

                                        <body name="bow_link_1" pos="-0 0 0.055" zaxis="-1 0 1">
                                            <joint name="bow_hinge_1" type="hinge" axis="1 0 0" class="bow_link"/>
                                            <geom name="bow_geom_1" type="capsule" fromto="0 0 0  0 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                            <body name="bow_link_2" pos="0 0 0.09">
                                                <joint name="bow_hinge_2" type="hinge" axis="1 0 0" class="bow_link"/>
                                                <geom name="bow_geom_2" type="capsule" fromto="0 0 0  0 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                <body name="bow_link_3" pos="0 0 0.09">
                                                    <joint name="bow_hinge_3" type="hinge" axis="1 0 0" class="bow_link"/>
                                                    <geom name="bow_geom_3" type="capsule" fromto="0 0 0  0 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                    <body name="bow_link_4" pos="0 0 0.09">
                                                        <joint name="bow_hinge_4" type="hinge" axis="1 0 0" class="bow_link"/>
                                                        <geom name="bow_geom_4" type="capsule" fromto="0 0 0  0 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                        <body name="bow_link_5" pos="0 0 0.09">
                                                            <joint name="bow_hinge_5" type="hinge" axis="1 0 0" class="bow_link"/>
                                                            <geom name="bow_geom_5" type="capsule" fromto="0 0 0  0 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                            <body name="bow_link_6" pos="0 0 0.07">
                                                                <joint name="bow_hinge_6" type="hinge" axis="1 0 0" class="bow_link"/>
                                                                <geom name="bow_geom_6" type="capsule" fromto="0 0 0  0 0 0.02" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                                <body name="bow_link_7" pos="0 0 0.02">
                                                                    <joint name="bow_hinge_7" type="hinge" axis="1 0 0" class="bow_link"/>
                                                                    <geom name="bow_geom_7" type="capsule" fromto="0 0 0  -0.05 0 0.09" size="0.005" rgba="0.4 0.25 0.1 1" mass="0.008"/>

                                                                    <body name="bow_tip" pos="-0.05 0 0.09">
                                                                        <joint name="bow_hinge_8" type="hinge" axis="1 0 0" class="bow_link"/>
                                                                        <geom name="bow_tip_geom" type="capsule" fromto="0 0 0  0 0 0.03" size="0.004" rgba="0.4 0.25 0.1 1" mass="0.004"/>
                                                                        <site name="bow_tip_site" pos="0 0 0.03" size="0.003"/>
                                                                    </body>
                                                                </body>
                                                            </body>
                                                        </body>
                                                    </body>
                                                </body>
                                            </body>
                                        </body>
                                    </body>

                                    <site name="bow_frog_site" pos="0 0 -0.01" size="0.003"/>
                                </body>

                            </body>

                        </body>

                    </body>

                </body>

            </body>

        </body>

    </worldbody>

    <actuator>

        <position joint="joint1"/>
        <position joint="joint2"/>
        <position joint="joint3"/>
        <position joint="joint4"/>

    </actuator>

    <include file="erhu.xml"/>

</mujoco>