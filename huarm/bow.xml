<mujoco model="bow">
    <default>
        <default class="bow_link">
            <joint stiffness="15" springref="0" damping="0.1"/>
        </default>
    </default>
        <!-- ============================== BOW ================================ -->
        <!-- Rigid-body chain of 8 capsule links with hinge joints + torsional
                 springs (stiffness/springref) approximating a continuously
                 bendable bow stick, held under camber by the hair tension. -->
        <!-- ================== BOW FROG / STICK CHAIN ==========================
             The bow_frog body (and the whole capsule-hinge chain hanging off
             it) is no longer a free-floating body here. It has been moved
             into arm.xml, nested inside the arm's "end_effector" body, so
             that the arm physically holds the bow via a compliant ("rubber")
             hinge joint (see arm.xml for "bow_frog_hinge"). This also means
             the old mocap "bow_target" + "teleop_coupling" weld used to
             teleoperate the frog directly are no longer needed (the arm is
             now what moves the bow) and have been removed. -->
        <worldbody>
            <!-- ============================ BOW HAIR ============================== -->
            <!-- 1-D flexcomp "cable" strung between the frog and the tip, pre-tensioned
                     by placing the two endpoints slightly farther apart than the hair's
                     natural length. Bending/twisting stiffness comes from the elasticity
                     plugin; axial tension comes from the (near-inextensible) edge
                     constraints being stretched at pinning time. -->
            <flexcomp name="bow_hair" type="grid" dim="1" count="36 1 1"
                                spacing="0.0155 0.001 0.001" radius="0.00025"
                                pos="0.575 0 0.645" euler="0 0 0"
                                rgba="0.95 0.92 0.85 1" mass="0.002">
                <edge equality="true" solref="0.001 1" solimp="0.9 0.94 0.0001"/>
                <plugin plugin="mujoco.elasticity.cable">
                    <config key="twist" value="5e6"/>
                    <config key="bend" value="5e6"/>
                </plugin>
                <contact selfcollide="none" condim="3" friction="1.2 0.02 0.001" solref="0.001 1" solimp="0.9 0.99 0.0005"/>
            </flexcomp>
        </worldbody>
    </mujoco>